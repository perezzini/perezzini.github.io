---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogPreview from '../../components/BlogPreview.astro'

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)
---

<BaseLayout
  title="Writing — Luciano Perezzini"
  description="Writing by Luciano Perezzini on AI, data systems, and software."
>
  <main
    class="max-w-[640px] mx-auto px-6 py-[72px] max-sm:px-5 max-sm:py-[40px]"
  >
    <a href="/" class="blog-back-link">← Home</a>
    <h1 class="blog-list-title">Writing</h1>
    {
      posts.length === 0 ? (
        <p class="text-center" style="color: #6e6e73">
          No posts yet.
        </p>
      ) : (
        posts.map((post) => (
          <BlogPreview
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
          />
        ))
      )
    }
  </main>
</BaseLayout>
