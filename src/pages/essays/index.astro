---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogPreview from '../../components/BlogPreview.astro'

const essays = (await getCollection('essays', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)
---

<BaseLayout
  title="Essays — Luciano Perezzini"
  description="Essays by Luciano Perezzini on AI, data systems, and software."
>
  <main
    class="max-w-[640px] mx-auto px-6 pt-[112px] pb-[72px] max-sm:px-5 max-sm:pt-[104px] max-sm:pb-[40px]"
  >
    <h2>Essays</h2>
    {
      essays.length === 0 ? (
        <p class="secondary" style="text-align:left">
          No essays yet.
        </p>
      ) : (
        essays.map((essay) => (
          <BlogPreview
            title={essay.data.title}
            description={essay.data.description}
            pubDate={essay.data.pubDate}
            slug={essay.id.replace(/\.mdx?$/, '')}
          />
        ))
      )
    }
  </main>
</BaseLayout>
